# llama-distributed server — environment variables
# Copy to .env and fill in values, or set directly in your hosting platform.

# ── Network ────────────────────────────────────────────────────────────────────
# Address to listen on
DIST_ADDR=:8080

# Public URL of this server (used in install one-liners and deep links)
# Must be the externally reachable URL including scheme.
DIST_PUBLIC_URL=https://your-deployment.fly.dev

# Apex host for per-pool subdomain routing (e.g. pool-name.yourdomain.com)
# Leave blank to use path-based routing instead (/v1/<pool-slug>/...)
DIST_APEX_HOST=yourdomain.com

# ── Storage ────────────────────────────────────────────────────────────────────
# SQLite database path
DIST_DB=./distpool.sqlite

# Directory for stored GGUF model shards (POST /api/models)
DIST_MODELS_DIR=./models-store

# Local cache for GitHub Release tarballs (speeds up repeated installs)
DIST_RELEASES_DIR=./releases-cache

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/applications/new
# Homepage URL:    https://your-deployment.fly.dev
# Callback URL:    https://your-deployment.fly.dev/auth/github/callback
DIST_GITHUB_CLIENT=your_client_id
DIST_GITHUB_SECRET=your_client_secret

# ── Security ───────────────────────────────────────────────────────────────────
# Secret key for signing session cookies — generate with: openssl rand -hex 32
DIST_SESSION_SECRET=change-me-in-production

# ── External tools (optional) ─────────────────────────────────────────────────
# Path to llama-split-gguf binary (only needed if hosting model shards)
DIST_SPLITTER=/usr/local/bin/llama-split-gguf
