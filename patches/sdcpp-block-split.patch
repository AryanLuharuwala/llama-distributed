+// ─── CF12-W6a: UNet block-split surface (llama-distributed extension) ──────
+//
+// Phase-1 stubs.  The public API exists so the llama-distributed role
+// bridge can link against the patched library today; the bodies switch to
+// the real forward_half-driven path in a follow-up patch.  Until then
+// callers get SD_SPLIT_ENOTSUP and fall back to the role chain.
+
+struct sd_split_state_t {
+    // Phase-2 carry-state:
+    //   sd::Tensor<float>            h;        // hidden state after middle_block
+    //   std::vector<sd::Tensor<float>> hs;    // skip residual stack
+    //   sd::Tensor<float>            emb;      // time + label embedding
+    //   int                          step_idx;
+    //   int                          sigma_idx;
+    //   bool                         is_final_step;
+    // For Phase 1 the struct is empty — bodies return ENOTSUP before
+    // touching it.
+    int  phase1_placeholder;
+};
+
+sd_split_state_t* sd_split_state_new(void) {
+    sd_split_state_t* st = (sd_split_state_t*)calloc(1, sizeof(sd_split_state_t));
+    return st;
+}
+
+void sd_split_state_free(sd_split_state_t* state) {
+    if (state != nullptr) {
+        free(state);
+    }
+}
+
+int sd_split_state_serialize(const sd_split_state_t* state, uint8_t** out, size_t* nbytes) {
+    (void)state;
+    if (out == nullptr || nbytes == nullptr) {
+        return SD_SPLIT_EINVAL;
+    }
+    *out    = nullptr;
+    *nbytes = 0;
+    return SD_SPLIT_ENOTSUP;
+}
+
+int sd_split_state_deserialize(const uint8_t* in, size_t nbytes, sd_split_state_t** out) {
+    (void)in;
+    (void)nbytes;
+    if (out == nullptr) {
+        return SD_SPLIT_EINVAL;
+    }
+    *out = nullptr;
+    return SD_SPLIT_ENOTSUP;
+}
+
+int sd_compute_unet_split_step(sd_ctx_t* sd_ctx,
+                               int which_half,
+                               int step_idx,
+                               int total_steps,
+                               sd_split_state_t* state) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr || state == nullptr) {
+        return SD_SPLIT_EINVAL;
+    }
+    if (which_half != 0 && which_half != 1) {
+        return SD_SPLIT_EINVAL;
+    }
+    if (step_idx < 0 || total_steps <= 0 || step_idx >= total_steps) {
+        return SD_SPLIT_EINVAL;
+    }
+    // Phase-1 stub.  The follow-up patch routes this through
+    // diffusion_model->compute_half() — UNetModel implements, other
+    // backbones return ENOTSUP at the bridge level.
+    return SD_SPLIT_ENOTSUP;
+}
+
+int sd_unet_block_count(const sd_ctx_t* sd_ctx) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr) {
+        return 0;
+    }
+    // Phase 1: 0 means "split not yet wired"; the planner falls back to
+    // the role chain.  When forward_half lands the SD1/SDXL paths return
+    // 2 (two halves), Phase 2 returns the finer subdivision count.
+    return 0;
+}
+
+const char* sd_loaded_backbone_tag(const sd_ctx_t* sd_ctx) {
+    if (sd_ctx == nullptr || sd_ctx->sd == nullptr) {
+        return "unknown";
+    }
+    SDVersion v = sd_ctx->sd->version;
+    if (sd_version_is_sdxl(v))       return "sdxl";
+    if (sd_version_is_sd2(v))        return "sd2";
+    if (sd_version_is_sd3(v))        return "sd3";
+    if (sd_version_is_flux(v))       return "flux";
+    if (sd_version_is_wan(v))        return "wan";
+    if (sd_version_is_qwen_image(v)) return "qwen_image";
+    if (sd_version_is_z_image(v))    return "z_image";
+    if (sd_version_is_sd1(v))        return "sd1";
+    if (v == VERSION_SVD)            return "svd";
+    return "unknown";
+}
+
